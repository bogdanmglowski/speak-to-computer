[General]
audio_backend=pipewire
hotkey_dictate=Super+Space
hotkey_translate_en=Super+slash
language=pl
threads=12
model=/media/extraHDD/whisper-models/ggml-small.bin
whisper_cli=~/whisper.cpp/build/bin/whisper-cli
activation_sound=activation_sound.wav
end_sound=end_sound.wav
wake_word_enabled=false
wake_word_phrase=alexa
wake_word_model_path=
wake_word_threshold=0.5
wake_word_sidecar_executable=~/.local/share/speak-to-computer/python/.venv/bin/python
wake_word_sidecar_script=~/.local/share/speak-to-computer/python/openwakeword_sidecar.py
vad_autostop_enabled=false
vad_aggressiveness=2
vad_end_silence_ms=900
vad_min_speech_ms=250

# activation_sound - sound played when recording starts (before UI appears)
#   - absolute path: /full/path/to/sound.wav
#   - relative path: sound.wav (searched in application directory, next to the binary)
#   - empty/unspecified: defaults to activation_sound.wav next to binary
#   - file must exist, otherwise skipped silently

# end_sound - sound played when recording stops (before transcription starts)
#   - same path resolution as activation_sound
#   - file must exist, otherwise skipped silently

# wake_word_enabled - when true, app listens in background for wake-word phrase
# wake_word_phrase - built-in phrase for openWakeWord, default: alexa
# wake_word_model_path - optional absolute or ~/ path to custom ONNX/TFLite model
#   - leave empty to auto-resolve bundled model from openwakeword package
# wake_word_threshold - trigger threshold (0.0, 1.0], default 0.5
# wake_word_sidecar_executable - Python interpreter used to run sidecar
#   - default: ~/.local/share/speak-to-computer/python/.venv/bin/python
# wake_word_sidecar_script - wake-word sidecar script path
#   - default: ~/.local/share/speak-to-computer/python/openwakeword_sidecar.py
# vad_autostop_enabled - when true, recording auto-stops after speech followed by silence
# vad_aggressiveness - WebRTC VAD mode (0..3), default 2
# vad_end_silence_ms - required trailing silence after speech before auto-stop, default 900
# vad_min_speech_ms - minimum continuous speech needed to arm auto-stop, default 250
